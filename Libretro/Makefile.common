# Generated by MesenCE NES Libretro port kit v1.0.16.
# Build only NES/FDS plus shared services required by the frontend.

LIBRETRO_DIR := .
SEVENZIP_DIR := ../SevenZip

SOURCES_C := $(shell find $(SEVENZIP_DIR) ../Utilities ../Lua -type f -name '*.c' ! -name 'serial.c' ! -name 'unix.c' ! -name 'unixdgram.c' ! -name 'unixstream.c')
DEBUGGER_SOURCES := $(shell find ../Core/Debugger -type f -name '*.cpp' ! -name 'ExpressionEvaluator.*.cpp') ../Core/Debugger/ExpressionEvaluator.Nes.cpp
